{
	// Place your snippets for latex here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
    "startv5":{
        "prefix": ["startv5"],
        "body": ["\\input{../../stock/en-tete_v5.tex}","","\\newcounter{chapitre}","\\setcounter{chapitre}{${1:numéro}}","","\\title{\\Large Chapitre ${1:numéro} \\newline \\Huge ${2:titre}}","","\\begin{document}","\\input{../../stock/commands.tex}","\\maketitle","","$0","","\\end{document}"],
        "description": "démarrer un nouveau projet"
    },

    "startv6": {
        "prefix": ["startv6", "go"],
        "body": [
            "\\input{../../../stock/en-tete_v6.tex}",
            "",
            "\\newcommand{\\titrechapitre}{${2:titre}}",
            "\\newcommand{\\numerochapitre}{${1:numéro}}",
            "",
            "\\renewcommand{\\headrulewidth}{0.4pt}",
            "\\renewcommand{\\footrulewidth}{0.4pt}",
            "\\fancyfoot[L]{Notes de Raphaël JONTEF}",
            "\\fancyfoot[C]{\\thepage}",
            "\\fancyfoot[R]{Enseirb-Matmeca}",
            "\\fancyhead[L]{Cours de Mathématiques}",
            "\\fancyhead[R]{\\titrechapitre}",
            "",
            "\\begin{document}",
            "\\input{../../../stock/commands.tex}",
            "",
            "% Page de titre custom",
            "\\setlength{\\headheight}{15pt}",
            "\\begin{titlepage}",
            "    \\centering",
            "    \\vspace*{3cm}",
            "    {\\huge Chapitre \\numerochapitre\\par}",
            "    {\\Huge \\bfseries\\titrechapitre\\par}",
            "    \\vspace{2cm}",
            "    {\\Large Notes rédigées par Raphaël JONTEF\\par}",
            "{\\Large ${3:Avec l'aide de }\\par}",
            "    \\vspace{0.5cm}",
            "    {\\normalsize Cours enseigné par ${4}\\par}",
            "    \\vspace{4cm}",
            "    {\\small Enseirb-Matmeca\\par}",
            "    {\\small filière informatique\\par}",
            "    \\vfill",
            "    {\\large \\today\\par}",
            "\\end{titlepage}",
            "",
            "% plan du cours",
            "\\tableofcontents",
            "\\newpage",
            "",
            "",
            "% -----------Corps du document--------------",
            "",
            "$0",
            "",
            "\\end{document}"
        ],
        "description": "Démarrer un nouveau projet avec en-tête, page de titre et commandes de proba"
}

,

    "règle de production":{
        "prefix": ["\\rp", "rp"],
        "body": "\\rp{$1}{$2}$0",
    },
    "élément différentiel":{
        "prefix": ["\\d", "d"],
        "body": "\\d{$1}$0",
    },

    "gradient":{
        "prefix": ["\\gradient", "gradient"],
        "body": "\\grad $0",
    },

    "divergence":{
        "prefix": ["\\divergence", "divergence"],
        "body": "\\div $0",
    },

    "rotationnel":{
        "prefix": ["\\rotationnel", "rotationnel"],
        "body": "\\rot $0",
    },

    "vecteur nabla":{
        "prefix": ["\\vnabla", "vnabla"],
        "body": "\\vnabla É$0",
    },
    
    "spectre":{
        "prefix": ["\\spectre", "spectre"],
        "body": "\\spectre($1)$0",
    },

    "virgule de maths":{
        "prefix": [",","\\,"],
        "body": ",\\, ",
    },

    "équivalence":{
        "prefix": "equivalence",
        "body": "\\Leftrightarrow",
    },

    "valeur absolue":{
        "prefix": ["abs","\\abs"],
        "body": "\\abs{$1}$0"
    },
    "sous-groupe engendré":{
        "prefix": ["sgEngendre","\\sgEngendre","sous-groupe engendré"],
        "body": "\\sgEngendre{$1}$0"
    },
    "groupe quotient":{
        "prefix": ["gpquotient","\\gpquotient","groupe quotient"],
        "body": "\\gpquotient{$1}$0"
    },
    "norme":{
        "prefix": ["norme","\\norme"],
        "body": "\\norme{$1}_{$2}$0"
    },
    "adhérence d'un ensemble":{
        "prefix": ["adhérence","\\adhérence"],
        "body": "\\adh{$1}$0"
    },

    "distance":{
        "prefix": ["distance","\\distance"],
        "body" : "\\distance{$1}{$2}$0"
    },

    "segment":{
        "prefix": ["seg","\\seg","segment","\\segment"],
        "body" : "\\seg{$1}{$2}$0"
    },

    "somme":{
        "prefix": ["somme","\\somme"],
        "body" : "\\somme{${1:min}}{${2:max}}$0"
    },
    "attracteur":{
        "prefix": ["attracteur","\\attracteur"],
        "body" : "\\attracteur{${1:joueur}}{${2:nombre de coups max}}$0"
    },
    "intégrale":{
        "prefix": ["integrale","\\integrale"],
        "body" : "\\inte{$1}{$2}$0"
    },
    
    "produit scalaire":{
        "prefix": ["scalaire","\\scalaire", "produit scalaire"],
        "body" : "\\scal{$1}{$2}$0"
    },


    "intervalle d'entiers":{
        "prefix": ["\\intint","intint"],
        "body": "\\intint{$1}{$2}$0",
    },

    "ensemble des matrices":{
        "prefix" : ["matrice", "\\matrice"],
        "body": "\\matrice{$1}$0",
    },

    "indicatrice":{
        "prefix": ["indicatrice", "\\indicatrice"],
        "body": "\\indicatrice$0"
    },

    "nouvelle notion":{
        "prefix" : ["notion", "\\notion", "\\noton", "notion", ""],
        "body": "\\notion$0",
    },

    "espérance":{
        "prefix": ["\\esperance", "esperance"],
        "body": "\\esperance$1{$2}$0"
    },

    "dérivée":{
        "prefix" : ["derive", "\\derive","dérivée"],
        "body": "\\derive{${1:ordre}}{${2:fonction}}{${3:variable}}$0"
    },

    "dérivée partielle":{
        "prefix" : ["derivepar", "\\derivepar","dérivée partielle"],
        "body": "\\derivepar{${1:ordre}}{${2:fonction}}{${3:variable}}$0"
    },

    "ensemble vide":{
        "prefix": ["varnothing","emptyset","\\varnothing","\\emptyset"],
        "body": "\\varnothing",
    },

    "flèche de limite":{
        "prefix": ["flechelim", "\\flechelim"],
        "body": "\\flechelim{${1:dessous}}{${2:dessus}}$0"
    },

    "vers l'infini":{
        "prefix": ["\\to + \\infty"],
        "body": "\\to + \\infty$0"
    },

    "symbole accompagné par le dessous":{
        "prefix": ["\\symbolelim","symbolelim"],
        "body": "\\symbolelim{${1:dessous}}{${2:dessus}}{${3:symbole}}$0"
    },

    "application":{
        "prefix": ["fonction","\\fonction","application","\\application"],
        "body": "\\fonction{${1:nom}}{${2:départ}}{${3:arrivée}}{${4:antécédent}}{${5:image}}"
    },

    "environnement enumeratebf":{
        "prefix": "enumeratebf",
        "body": ["\\begin{enumeratebf}","\t\\item $0","\\end{enumeratebf}"]
    },

    "environnement itemize":{
        "prefix": "itemize",
        "body": ["\\begin{itemize}","\t\\item $0","\\end{itemize}"]
    },

    "environnement Démonstration":{
        "prefix": "demonstration",
        "body": ["\\begin{demonstration}","\t$0", "\\end{demonstration}"],
    },

    "environnement Théorème":{
        "prefix": "theoreme",
        "body": ["\\begin{theoreme}{${2:numero}}{${3:titre}}","\t$0","\\end{theoreme}"],
    },
    "environnement Proposition":{
        "prefix": "proposition",
        "body": ["\\begin{proposition}{${2:numero}}{${3:titre}}","\t$0","\\end{proposition}"],
    },
    "environnement Lemme":{
        "prefix": "lemme",
        "body": ["\\begin{lemme}{${2:numero}}{${3:titre}}","\t$0","\\end{lemme}"],
    },
    "environnement Définition":{
        "prefix": "definition",
        "body": ["\\begin{definition}{${2:numero}}{${3:titre}}","\t$0","\\end{definition}"],
    },
    "environnement Exemple":{
        "prefix": "exemple",
        "body": ["\\begin{exemple}{${2:numero}}{${3:titre}}","\t$0","\\end{exemple}"],
    },
    "environnement Exercice":{
        "prefix": "exercice",
        "body": ["\\begin{exercice}{${2:numero}}{${3:titre}}","\t$0","\\end{exercice}"],
    },
    "environnement Remarques":{
        "prefix": "remarque",
        "body": ["\\begin{remarque}{${2:numero}}{${3:titre}}","\t$0","\\end{remarque}"],
    },
    "environnement OCaml":{
        "prefix": "OCaml",
        "body": ["\\begin{implementation}{${3:titre}}","\t\\begin{lstOCaml}","\t\t$0","\t\\end{lstOCaml}","\\end{implementation}"],
    },
    "environnement C":{
        "prefix": "C",
        "body": ["\\begin{implementation}{${3:titre}}","\t\\begin{lstC}","\t\t$0","\t\\end{lstC}","\\end{implementation}"],
    },
    "environnement Langage Naturel":{
        "prefix": ["langage naturel","LNat"],
        "body": ["\\begin{implementation}{${3:titre}}","\t\\begin{lstLNat}","\t\t$0","\t\\end{lstLNat}","\\end{implementation}"],
    },

    "création d'une commande":{
        "prefix": ["newcommand","\\newcommand","nouvelle commande"],
        "body": "\\newcommand{${1:nom}}[${2:nb_paramètres}]{${3:action}}\n$0"
    },
}