{
    "security.workspace.trust.untrustedFiles": "open",
    "editor.smoothScrolling": true,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.renderWhitespace": "none",
    "python.analysis.autoImportCompletions": true,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 5000,
    "code-runner.runInTerminal": true,
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    // "terminal.integrated.defaultProfile.windows": "Cygwin",
    "debug.terminal.clearBeforeReusing": true,
    "code-runner.clearPreviousOutput": false,
    "code-runner.executorMap": {
        "javascript": "cls && node",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
        // "c": "gcc $fullFileName -Wextra -Wall -fsanitize=address -o $fileNameWithoutExt && ./$fileNameWithoutExt",
        "c" : "cd $dir" ,
        "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "php": "php",
        "python": "python $fullFileName",
        "perl": "perl",
        "perl6": "perl6",
        "ruby": "ruby",
        "go": "go run",
        "lua": "lua",
        "groovy": "groovy",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "bat": "cmd /c",
        "shellscript": "bash",
        "fsharp": "fsi",
        "csharp": "scriptcs",
        "vbscript": "cscript //Nologo",
        "typescript": "ts-node",
        "coffeescript": "coffee",
        "scala": "scala",
        "swift": "swift",
        "julia": "julia",
        "crystal": "crystal",
        "ocaml": "cd $dir",
        // "ocaml": "ocaml $fullFileName",
        "r": "Rscript",
        "applescript": "osascript",
        "clojure": "lein exec",
        "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
        "racket": "racket",
        "scheme": "csi -script",
        "ahk": "autohotkey",
        "autoit": "autoit3",
        "dart": "dart",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        "haskell": "runhaskell",
        "nim": "nim compile --verbosity:0 --hints:off --run",
        "lisp": "sbcl --script",
        "kit": "kitc --run",
        "v": "v run",
        "sass": "sass --style expanded",
        "scss": "scss --style expanded",
        "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
        "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "sml": "cd $dir && sml $fileName"
    },
    "editor.wordWrap": "bounded",
    "editor.wrappingIndent": "deepIndent",
    "code-runner.ignoreSelection": true,
    "settingsSync.ignoredSettings": [
        "editor.fontSize",
        "terminal.integrated.fontSize",
        "workbench.tree.indent",
        "editor.wordWrapColumn",
        "editor.cursorBlinking",
        "editor.cursorSmoothCaretAnimation",
        "editor.find.cursorMoveOnType",
        "-python.defaultInterpreterPath"
    ],
    "explorer.confirmDragAndDrop": false,
    "editor.detectIndentation": false,
    "python.terminal.executeInFileDir": true,
    "[python]": {
        "editor.formatOnType": true
    },
    "python.languageServer": "Pylance",
    "workbench.editor.wrapTabs": true,
    "python.autoComplete.extraPaths": [
    
    ],
    "python.analysis.extraPaths": [],
    "editor.fontFamily": "Consolas,Monocraft, 'Courier New', monospace",
    "jupyter.askForKernelRestart": false,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "files.exclude": {
        ".replit": true,
        "replit.nix": true,
        "venv": true
    },
    "workbench.preferredLightColorTheme": "Solarized Light",
    "python.defaultInterpreterPath": "/usr/bin/python3",
    "settingsSync.keybindingsPerPlatform": false,
    "workbench.startupEditor": "none",
    "diffEditor.ignoreTrimWhitespace": false,
    "code-runner.executorMapByGlob": {

        "pom.xml": "cd $dir && mvn clean package"
    },
    "workbench.panel.defaultLocation": "right",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        },
        "Cygwin":{
            "path": "A:\\Programmes\\OCaml64\\Cygwin.bat"
        }
        
    },
    "code-runner.saveFileBeforeRun": true,
    "code-runner.executorMapByFileExtension": {
        // ".tex": "cd $dir && pdflatex -shell-escape $fileName",
        ".tex": "cd $dir && pdflatex  -shell-escape -interaction=batchmode $fileName",
        ".vb" : "cd $dir && vbc /nologo $fileName && $dir$fileNameWithoutExt",
        ".vbs": "cscript //Nologo",
        ".scala": "scala",
        ".jl": "julia",
        ".cr": "crystal",
        ".ml": "ocaml",
        ".zig": "zig run",
        ".exs": "elixir",
        ".hx": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        ".rkt": "racket",
        ".scm": "csi -script",
        ".ahk": "autohotkey",
        ".au3": "autoit3",
        ".kt": "cd $dir && kotlinc $fileName -include-runtime -d $fileNameWithoutExt.jar && java -jar $fileNameWithoutExt.jar",
        ".kts": "kotlinc -script",
        ".dart": "dart",
        ".pas": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        ".pp": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        ".d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        ".hs": "runhaskell",
        ".nim": "nim compile --verbosity:0 --hints:off --run",
        ".csproj": "dotnet run --project",
        ".fsproj": "dotnet run --project",
        ".lisp": "sbcl --script",
        ".kit": "kitc --run",
        ".v": "v run",
        ".vsh": "v run",
        ".sass": "sass --style expanded",
        ".cu": "cd $dir && nvcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        ".ring": "ring",
        ".sml": "cd $dir && sml $fileName",
        ".mojo": "mojo run"
},
"[ocaml]": {
    "editor.tabSize": 4
},
"window.menuBarVisibility": "visible",
"explorer.confirmDelete": false,
"explorer.sortOrder": "type",
"latex-workshop.latex.autoBuild.run": "never",
"terminal.integrated.gpuAcceleration": "off",
"editor.find.cursorMoveOnType": false,
"terminal.integrated.smoothScrolling": true,
"extensions.ignoreRecommendations": true,
"remote.SSH.remotePlatform": {
    "176.138.186.229": "linux",
    "almapedago": "linux",
    "192.168.137.98": "linux"
},
"terminal.integrated.persistentSessionScrollback": 10000,
"terminal.integrated.scrollback": 10000,
"settingsSync.ignoredExtensions": [
    "formulahendry.code-runner"
],
"continue.enableTabAutocomplete": false,
"continue.showInlineTip": false,
"github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "cpp": true
},
"git.openRepositoryInParentFolders": "always",
"files.associations": {
    "*.s": "asm-list-markdown-codeblock",
    "*.{a80,z80,asm,inc,s}": "asm-collection",
    "*.{list,lis}": "asm-collection-list"
},
"workbench.editor.enablePreview": false,
"github.copilot.nextEditSuggestions.enabled": true,
"explorer.confirmPasteNative": false,
"chat.viewSessions.orientation": "stacked",
"diffEditor.renderSideBySide": true,
"C_Cpp.default.compilerPath": "/run/current-system/sw/bin/gcc",
"editor.mouseWheelScrollSensitivity": 2.5,
"editor.minimap.enabled": false,
"workbench.colorTheme": "Solarized Light",
}